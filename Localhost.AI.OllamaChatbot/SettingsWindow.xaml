<Window x:Class="Localhost.AI.LlmClient.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Settings" FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Ollama Configuration -->
                <GroupBox Header="Ollama Configuration" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,15">
                            <Label Content="Ollama URL:" FontWeight="Bold"/>
                            <TextBox x:Name="OllamaUrlTextBox" Text="{Binding OllamaUrl}" 
                                     Height="30" FontSize="14"/>
                            <TextBlock Text="Enter the URL where Ollama is running (e.g., http://localhost:11434)" 
                                       FontSize="12" Foreground="Gray" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <Label Content="Default Model:" FontWeight="Bold"/>
                            <ComboBox x:Name="ModelComboBox" SelectedItem="{Binding DefaultModel}" 
                                      Height="30" FontSize="14" IsEditable="True"/>
                            <TextBlock Text="Select or enter the default model to use for conversations" 
                                       FontSize="12" Foreground="Gray" Margin="0,5,0,0"/>
                        </StackPanel>

                        <Button x:Name="TestConnectionButton" Content="Test Connection" 
                                Height="35" Background="#4CAF50" Foreground="White" 
                                BorderThickness="0" FontWeight="Bold" Click="TestConnection_Click"/>
                    </StackPanel>
                </GroupBox>

                <!-- Chat Configuration -->
                <GroupBox Header="Chat Configuration" Padding="15">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,15">
                            <Label Content="Your Name:" FontWeight="Bold"/>
                            <TextBox x:Name="UserNameTextBox" Text="{Binding UserName}" 
                                     Height="30" FontSize="14"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <Label Content="Assistant Name:" FontWeight="Bold"/>
                            <TextBox x:Name="BotNameTextBox" Text="{Binding BotName}" 
                                     Height="30" FontSize="14"/>
                        </StackPanel>

                        <CheckBox x:Name="AutoScrollCheckBox" Content="Auto-scroll to new messages" 
                                  IsChecked="{Binding AutoScroll}" FontSize="14" Margin="0,0,0,10"/>
                        
                        <CheckBox x:Name="ShowTimestampsCheckBox" Content="Show timestamps" 
                                  IsChecked="{Binding ShowTimestamps}" FontSize="14"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button x:Name="CancelButton" Content="Cancel" Width="80" Height="35" 
                    Click="Cancel_Click" Margin="0,0,10,0"/>
            <Button x:Name="SaveButton" Content="Save" Width="80" Height="35" 
                    Background="#2196F3" Foreground="White" BorderThickness="0" 
                    FontWeight="Bold" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
