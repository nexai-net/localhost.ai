<Window x:Class="Localhost.AI.LlmClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Localhost.AI.LlmClient"
        xmlns:converters="clr-namespace:Localhost.AI.LlmClient.Converters"
        xmlns:helpers="clr-namespace:Localhost.AI.LlmClient.Converters"
        mc:Ignorable="d"
        Title="Ollama Chatbot" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- Converters -->
        <converters:MessageBackgroundConverter x:Key="MessageBackgroundConverter"/>
        <converters:MessageCornerRadiusConverter x:Key="MessageCornerRadiusConverter"/>
        <converters:MessageMarginConverter x:Key="MessageMarginConverter"/>
        <converters:MessageAlignmentConverter x:Key="MessageAlignmentConverter"/>
        <converters:MessageForegroundConverter x:Key="MessageForegroundConverter"/>

        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Message Bubble Style -->
        <Style x:Key="UserMessageStyle" TargetType="Border">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="CornerRadius" Value="18,18,4,18"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="50,5,10,5"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <Style x:Key="BotMessageStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="18,18,18,4"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="10,5,50,5"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="ErrorMessageStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFCDD2"/>
            <Setter Property="CornerRadius" Value="18,18,18,4"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="10,5,50,5"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <!-- Markdown Text Converter -->
        <converters:MarkdownTextConverter x:Key="MarkdownTextConverter"/>
        <converters:MarkdownToFlowDocumentConverter x:Key="MarkdownToFlowDocumentConverter"/>
        <converters:MarkdownToFlowDocumentMultiConverter x:Key="MarkdownToFlowDocumentMultiConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="19*"/>
            <ColumnDefinition Width="30*"/>
            <ColumnDefinition Width="32*"/>
            <ColumnDefinition Width="919*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="20,15" 
                Effect="{x:Null}" Grid.ColumnSpan="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Localhost.AI.Client" FontSize="24" FontWeight="Bold" 
                               Foreground="#333"/>
                    <TextBlock x:Name="ConnectionStatus" Text="Connected" 
                               FontSize="12" Foreground="Red"/>
                </StackPanel>

                <Button Grid.Column="1" x:Name="SettingsButton" Content="⚙️ Settings" 
                        Style="{StaticResource ModernButton}" 
                        Click="Settings_Click" Margin="0,0,10,0"/>
            </Grid>
        </Border>

        <!-- Chat Area -->
        <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer" 
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="True"
                      ScrollChanged="ChatScrollViewer_ScrollChanged"
                      Padding="20,20,20,40" Background="#F5F5F5" Grid.ColumnSpan="4">
            <ItemsControl x:Name="ChatItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{Binding IsUser, Converter={StaticResource MessageBackgroundConverter}}"/>
                                    <Setter Property="CornerRadius" Value="{Binding IsUser, Converter={StaticResource MessageCornerRadiusConverter}}"/>
                                    <Setter Property="Padding" Value="15,10"/>
                                    <Setter Property="Margin" Value="{Binding IsUser, Converter={StaticResource MessageMarginConverter}}"/>
                                    <Setter Property="HorizontalAlignment" Value="{Binding IsUser, Converter={StaticResource MessageAlignmentConverter}}"/>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock FontSize="14" TextWrapping="Wrap"
                                           helpers:MarkdownTextHelper.FormattedText="{Binding Content}"
                                           helpers:MarkdownTextHelper.TextColor="{Binding IsUser, Converter={StaticResource MessageForegroundConverter}}"/>
                                <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm'}" 
                                           FontSize="10" Opacity="0.7" 
                                           HorizontalAlignment="Right" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input Area -->
        <Border Grid.Row="2" Background="White" Padding="20" 
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Grid.ColumnSpan="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="MessageTextBox" Grid.Column="0" 
                         Height="40" FontSize="14" Padding="15,10"
                         VerticalContentAlignment="Center"
                         Background="#F8F8F8" BorderBrush="#E0E0E0"
                         KeyDown="MessageTextBox_KeyDown"
                         TextChanged="MessageTextBox_TextChanged"/>

                <Button Grid.Column="1" x:Name="SendButton" Content="Send" 
                        Style="{StaticResource ModernButton}" 
                        Height="40" Width="80" Margin="10,0,0,0"
                        Click="Send_Click" IsEnabled="False"/>
            </Grid>
        </Border>
    </Grid>
</Window>
